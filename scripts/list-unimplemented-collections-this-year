    try-python
    try-random
    try-range-based-for
    try-rust
    try-srfi-45
    try-srfi-64
    try-tagged-template
    wc
)

sort \
    <(daily-coding stats -b | grep -P "^$(date '+%Y')" | awk '{print $2}') \
    <(daily-coding stats -b | grep -P "^$(date '+%Y')" | awk '{print $2}') \
    <(daily-coding stats -b | grep -P '^(?!'"$(date '+%Y')"')\d' | awk '{print $2}') \
    | uniq -u \
    | grep -vE "^($(IFS='|'; echo "${hidden_collection_names[*]}"))$"

