    #dutch-national-flag-problem
    extname
    factorial
    #fold
    form
    #functor
    high-order-function
    hypothesis-testing
    insertion-sort
    itertools
    #kmp_search
    learn-probability
    markdown-toggle
    #mathematics
    maximum
    optical-illusion
    pattern-expansion
    #permutations
    permutations-combinations
    quick-sort-benchmark
    #random
    recommendation
    rev
    sazae-family
    searching
    selection-sort
    sorting
    sorting-algorithm
    srfi-1
    strip-heredoc
    swap
    tac
    timed-cache
    #topological-sort
    tree-walk
    trivial-comment-remover
    try-alist
    try-cabal
    try-erlang
    try-foreach
    try-functools
    try-go
    try-goroutine
    try-htmx
