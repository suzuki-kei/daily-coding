#!/usr/bin/env bash -l

set -eu -o pipefail

declare -ra hidden_collection_names=(
    #american-flag-sort
    assign-contents-of-file-to-variable
    #bayesian-inference
    #chunked
    #combination
    concatenate-string
    data-type-name
